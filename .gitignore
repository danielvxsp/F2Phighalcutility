# Compiled Java class files (These are generated locally, don't upload them)
*.class
bin/
out/
build/
exe/

# Package Files (Ignore generated executables)
*.jar
*.war
*.ear
*.zip
*.tar.gz

# EXCEPTION: Do NOT ignore the library folder. 
!lib/*.jar

# OS generated files (Hidden files created by Mac/Windows)
.DS_Store
.DS_Store?
._*
.Trashes
ehthumbs.db
Thumbs.db
